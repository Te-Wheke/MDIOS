#!/bin/sh

MDI_BOOT_PIDS=""
MDI_BOOT_PID_FILE="/opt/mdi/state/boot-animation-pids"
MDI_CLEANED=0

mdi_pid_register() {
  pid="$1"
  case "$pid" in ''|*[!0-9]*) return 0 ;; esac
  MDI_BOOT_PIDS="${MDI_BOOT_PIDS:+$MDI_BOOT_PIDS }$pid"
  printf '%s\n' "$pid" >> "$MDI_BOOT_PID_FILE" 2>/dev/null || true
