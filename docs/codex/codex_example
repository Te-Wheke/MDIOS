  tar -czf "$BACKUP_TAR_TMP" --exclude='/opt/mdi/backups' /opt/mdi 2>/dev/null || {
    echo "Backup failed. Refusing to continue."
    exit 1
  }
  mv -f "$BACKUP_TAR_TMP" "$BACKUP_TAR" 2>/dev/null || true
fi

