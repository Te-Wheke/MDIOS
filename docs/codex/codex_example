  fi
  for pid in $MDI_BOOT_PIDS; do
    case "$pid" in ''|*[!0-9]*) ;; *) kill "$pid" 2>/dev/null || true ;; esac
  done
  for pid in $MDI_BOOT_PIDS; do
    case "$pid" in ''|*[!0-9]*) ;; *) wait "$pid" 2>/dev/null || true ;; esac
