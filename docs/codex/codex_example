}

mdi_find_eye_asset() {
  for CANDIDATE in \
    /opt/mdi/assets/ascii/ascii-art5-small.txt \
    /opt/mdi/tui/ascii-art5-small.txt \
    /opt/mdi/boot/ascii-art5-small.txt \
