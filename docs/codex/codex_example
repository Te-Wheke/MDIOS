MDI_INSTALLER_PATH="${MDI_INSTALLER_PATH:-./.mdi-v1-full.sh}"
cat > "$MDI_INSTALLER_PATH" <<'MDI_INSTALLER_EOF'
#!/bin/sh
set -eu

TS="$(date +%Y%m%d-%H%M%S)"

# Backups must not live inside the Alpine runtime tree (/opt/mdi) because they
# quickly consume storage during iteration. Store a single rolling backup in
# the Termux host filesystem, and only refresh it every N runs.
HOST_BACKUP_DIR="/data/data/com.termux/files/home/MDI/mdi-backups"
BACKUP_EVERY="${MDI_BACKUP_EVERY:-10}"
PATCH_COUNT_FILE="$HOST_BACKUP_DIR/mdi-v1-patch-count.txt"
BACKUP_TAR_TMP="$HOST_BACKUP_DIR/opt-mdi-before-v1-latest.tar.gz.tmp"
BACKUP_TAR="$HOST_BACKUP_DIR/opt-mdi-before-v1-latest.tar.gz"

mkdir -p \
  "$HOST_BACKUP_DIR" \
  /opt/mdi/bin \
  /opt/mdi/boot \
  /opt/mdi/tui \
  /opt/mdi/state \
  /opt/mdi/log \
  /opt/mdi/art \
  /opt/mdi/assets/ascii \
  /opt/mdi/assets/boot/ultra-compact \
  /opt/mdi/assets/boot/phone \
  /opt/mdi/assets/boot/tablet \
  /opt/mdi/assets/boot/desktop \
  /opt/mdi/boot/lib \
  /opt/mdi/boot/phases \
  /opt/mdi/boot/themes \
  /opt/mdi/boot/tests \
  /opt/mdi/backups

V2_BACKUP_TAR="/opt/mdi/backups/boot-v1-visual-prototype-$TS.tar.gz"
rm -f "$V2_BACKUP_TAR.tmp" 2>/dev/null || true
tar -czf "$V2_BACKUP_TAR.tmp" --exclude='/opt/mdi/backups' /opt/mdi 2>/dev/null || {
  echo "Backup failed. Refusing to continue."
  exit 1
}
mv -f "$V2_BACKUP_TAR.tmp" "$V2_BACKUP_TAR"

# Patch/run counter (persists on Termux host). Backup refresh only every N runs.
patch_n=0
if [ -f "$PATCH_COUNT_FILE" ]; then
  patch_n="$(cat "$PATCH_COUNT_FILE" 2>/dev/null || echo 0)"
fi
case "$patch_n" in ''|*[!0-9]*) patch_n=0 ;; esac
patch_n=$((patch_n + 1))
printf '%s\n' "$patch_n" > "$PATCH_COUNT_FILE" 2>/dev/null || true

do_backup=0
case "$BACKUP_EVERY" in ''|*[!0-9]*) BACKUP_EVERY=10 ;; esac
if [ "$BACKUP_EVERY" -le 1 ]; then
  do_backup=1
elif [ $((patch_n % BACKUP_EVERY)) -eq 0 ]; then
  do_backup=1
fi

