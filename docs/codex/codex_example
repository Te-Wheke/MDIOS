warn() {
  WARNINGS=$((WARNINGS+1))
  row WARN "$1" "$2"
}

fail_or_warn() {
  AREA="$1"
  MSG="$2"

  if [ "$MDI_WARN_PROCEED" = "yes" ]; then
    warn "$AREA" "$MSG"
  else
    row FAIL "$AREA" "$MSG"
